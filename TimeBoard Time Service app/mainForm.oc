}


handler syncTimeBtn.onselect() {
	int err;
	int retries;
	bool resp;
	
	if (offsetPopup.text == "Select...") {
		alert("Please select the GMT offset according to the nearest city of your current location.");
		return;
	}
	
	retries = lparse(retriesField.text);
	
	if (retries <= 0) {
		alert("Retry attempts must be in the range 1 to 9.");
		return;
	}
	
	// Save preferences
	resp = setNewPrefs(offsetList.selitem, retries);
	if (!resp) {
		alert("Error trying to save preferences.");
	}
	
	draw.begin();
    draw.bitmap(internetConnectingBMP, 8, 22);
    draw.end();
	
	err = downloadTime();
	
	if (err == 0) {
	
    	processUTCResponse();
	
    	draw.begin();
    	draw.bitmap(internetSuccessBMP, 8, 22);
    	draw.end();
	
    	setDateTime();
	}
	else {
	
    	draw.begin();
    	draw.bitmap(internetErrorBMP, 8, 22);
    	draw.end();
	
    	alertc(
        	"Error",
        	"Unable to get time from the Internet.\nError code: " + err,
        	"OK",
        	alertError
    	);
	}
}


handler mainForm.ontimer() {
	string yyyy;
	string MM;
	string dd;
	string hh;
	string mm;
	string ss;
	
	deviceDate.now();
	timerSecond = deviceDate.sec;

	if (!mainForm.obscured && timerSecond != timerLastSecond) {
		yyyy = "" + deviceDate.year;
	
		if (deviceDate.month < 10)
			MM = "0" + deviceDate.month;
		else
			MM = "" + deviceDate.month;
	
		if (deviceDate.day < 10)
			dd = "0" + deviceDate.day;
		else
			dd = "" + deviceDate.day;
	
		if (deviceDate.hour < 10)
			hh = "0" + deviceDate.hour;
		else
			hh = "" + deviceDate.hour;
	
		if (deviceDate.min < 10)
			mm = "0" + deviceDate.min;
		else
			mm = "" + deviceDate.min;
	
		if (deviceDate.sec < 10)
			ss = "0" + deviceDate.sec;
		else
			ss = "" + deviceDate.sec;
	
		NDateLabel.text = yyyy + "-" + MM + "-" + dd + "      ";
		NTimeLabel.text = hh + ":" + mm + ":" + ss + "      ";
	}
	
	timerLastSecond = timerSecond;
	timer(20);
}


handler TBTSExitBtn.onselect() {
	TBTS.abort();
}


handler menu0101.onselect() {
	alert("TimeBoard Time Service v1.0.1 (Prototype)\n@coloraturip\©2026");
