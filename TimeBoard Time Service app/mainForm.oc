	offsetList.setitems(38, offsetNames);
		
	// Set popup and retry field
	offsetPopup.text = offsetNames[appPrefs[0].selectedOffsetIndex];
	offsetList.selitem = appPrefs[0].selectedOffsetIndex;
	retriesField.text = appPrefs[0].connectionAttempts;
	
