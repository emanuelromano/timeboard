void drawHand(float angle,
			  int length,
			  int centerX,
			  int centerY,
			  int r,
			  int g,
			  int b)
{
	int x, y;
	
	mainBuffer.begin();
	mainBuffer.fgRGB(r, g, b);

	x = centerX + (cos(angle) * length);
	y = centerY + (sin(angle) * length);

	mainBuffer.line(clrFG, centerX, centerY, x, y);
	mainBuffer.end();
}


