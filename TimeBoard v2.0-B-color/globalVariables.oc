	minuteDigit1, minuteDigit2,
	secondDigit1, secondDigit2,
	
	charge; // Battery

int	centerX, centerY,

	hourLength = 15,
	minuteLength = 20,
	secondLength = 20;

float oldHourAngle,
	oldMinuteAngle,
	oldSecondAngle;


// Widgets
int startX1 = 8,
	startY1 = 8,
	
	startX2 = 84,
	startY2 = 8,
	
